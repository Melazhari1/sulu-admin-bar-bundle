{
    "name": "elazhari/sulu-admin-bar-bundle",
    "description": "Frontend admin bar for the Sulu CMS: edit the current page or custom entity, add new content and log out, directly from the website.",
    "license": "MIT",
    "type": "symfony-bundle",
    "keywords": [
        "sulu",
        "sulucms",
        "admin-bar",
        "toolbar",
        "symfony-bundle"
    ],
    "authors": [
        {
            "name": "M.Elazhari",
            "email": "elazharimohamedp@gmail.com"
        }
    ],
    "homepage": "https://github.com/elazhari/sulu-admin-bar-bundle",
    "support": {
        "issues": "https://github.com/elazhari/sulu-admin-bar-bundle/issues",
        "source": "https://github.com/elazhari/sulu-admin-bar-bundle"
    },
    "require": {
        "php": "^7.2 || ^8.0",
        "doctrine/persistence": "^1.3 || ^2.0 || ^3.0 || ^4.0",
        "sulu/sulu": "^2.0 || ^3.0",
        "symfony/asset": "^4.4 || ^5.4 || ^6.4 || ^7.0",
        "symfony/config": "^4.4 || ^5.4 || ^6.4 || ^7.0",
        "symfony/dependency-injection": "^4.4 || ^5.4 || ^6.4 || ^7.0",
        "symfony/http-foundation": "^4.4 || ^5.4 || ^6.4 || ^7.0",
        "symfony/http-kernel": "^4.4 || ^5.4 || ^6.4 || ^7.0",
        "symfony/routing": "^4.4 || ^5.4 || ^6.4 || ^7.0",
        "symfony/security-core": "^4.4 || ^5.4 || ^6.4 || ^7.0",
        "symfony/twig-bridge": "^4.4 || ^5.4 || ^6.4 || ^7.0",
        "symfony/yaml": "^4.4 || ^5.4 || ^6.4 || ^7.0",
        "twig/twig": "^2.13 || ^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^8.5 || ^9.6"
    },
    "autoload": {
        "psr-4": {
            "Elazhari\\SuluAdminBarBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Elazhari\\SuluAdminBarBundle\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
